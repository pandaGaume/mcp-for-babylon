{
  "name": "@mcpbabylon/root",
  "version": "0.1.0",
  "description": "",
  "type": "module",
  "main": "dist/index.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pandaGaume/mcp-for-babylon.git"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.2.0",
    "rimraf": "~6.0.1",
    "selfsigned": "^2.4.1",
    "typescript": "^5.4.0"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "workspaces": [
    "packages/**/*"
  ],
  "scripts": {
    "build:dev": "tsc -b",
    "build:watch": "tsc -b --watch",
    "lint": "npm run lint:check",
    "lint:check": "eslint \"packages/**/src/**/*.{ts,tsx,js,json}\" --quiet",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "npm run format:check && npm run format:fix",
    "format:check": "prettier --check \"packages/**/src/**/*.{ts,tsx,js,json,scss,css}\"",
    "bundle": "npm run bundle --workspace=@dev/core && npm run bundle --workspace=@dev/babylon",
    "bundle:dev": "npm run bundle:dev --workspace=@dev/core && npm run bundle:dev --workspace=@dev/babylon",
    "bundle:watch": "npm run bundle:watch --workspace=@dev/core",
    "deploy:bundles": "node scripts/deploy-bundles.mjs",
    "build:all": "npm run build:dev && npm run bundle && npm run deploy:bundles",
    "build:all:dev": "npm run build:dev && npm run bundle:dev && npm run deploy:bundles",
    "server:build": "npm run build --workspace=@dev/tunnel",
    "server:start": "npm run server:build && npm run start --workspace=@dev/tunnel",
    "gen-cert": "node scripts/gen-cert.mjs"
  },
  "engines": {
    "node": ">=20.11.0 <23.0.0",
    "npm": ">=8.0.0"
  },
  "dependencies": {
    "tslib": "^2.8.1"
  }
}
