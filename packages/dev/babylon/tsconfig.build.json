{
    "extends": "../../../tsconfig.build.json",

    "compilerOptions": {
        "composite": true,
        "outDir": "./dist",
        "rootDir": "./src",
        "skipLibCheck": true,
        "paths": {
            "babylon/*": ["dev/babylon/src/*"]
        }
    },

    "references": [
        { "path": "../core/tsconfig.build.json" },
        { "path": "../filters/tsconfig.build.json" },
        { "path": "../geodesy/tsconfig.build.json" },
        { "path": "../behaviors/tsconfig.build.json" }
    ],

    "include": ["./src/**/*.ts", "./src/**/*.tsx"],
    "exclude": ["**/node_modules", "**/dist"]
}
